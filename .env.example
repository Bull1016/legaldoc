# ==============================================
# LegalDoc - Variables d'environnement
# ==============================================
# Copiez ce fichier en .env.local pour le développement
# Configurez les vraies valeurs sur Vercel pour la production

# --- Base de données (Supabase PostgreSQL) ---
# Récupérez depuis : Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# --- NextAuth ---
# Générez avec : openssl rand -base64 32
NEXTAUTH_SECRET="votre-secret-nextauth-tres-long-et-aleatoire"
NEXTAUTH_URL="http://localhost:3000"
# En production sur Vercel, NEXTAUTH_URL n'est pas nécessaire si la variable VERCEL_URL est définie

# --- Supabase Storage (pour les uploads de fichiers) ---
# Récupérez depuis : Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- Email (Resend) - optionnel pour MVP ---
# Créez un compte sur resend.com et récupérez votre API key
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@votredomaine.com"

# --- Admin par défaut (utilisé dans le seed) ---
ADMIN_EMAIL="admin@legaldoc.fr"
ADMIN_PASSWORD="Admin@LegalDoc2026!"
