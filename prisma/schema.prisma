// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  client
  admin
  juriste
  expert_compta
}

enum RequiredRole {
  juriste
  expert_compta
  admin
}

enum RequestStatus {
  draft
  submitted
  assigned
  in_review
  completed
  refused
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  fullName     String
  phone        String?
  role         Role      @default(client)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  requests      Request[] @relation("UserRequests")
  assignedCases Request[] @relation("AssignedRequests")

  @@map("users")
}

model Service {
  id           String       @id @default(uuid())
  name         String
  description  String
  category     String?
  basePrice    Decimal?     @db.Decimal(10, 2)
  formSchema   Json
  requiredRole RequiredRole @default(juriste)
  active       Boolean      @default(true)
  icon         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  requests Request[]

  @@map("services")
}

model Request {
  id                String        @id @default(uuid())
  uniqueCode        String        @unique
  userId            String
  serviceId         String
  status            RequestStatus @default(draft)
  formData          Json          @default("{}")
  documentsUploaded Json[]        @default([])
  assignedTo        String?
  finalDocumentUrl  String?
  notesInternal     String?
  refusalReason     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user         User          @relation("UserRequests", fields: [userId], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [serviceId], references: [id])
  assignedUser User?         @relation("AssignedRequests", fields: [assignedTo], references: [id])
  notifications Notification[]

  @@map("requests")
}

model Notification {
  id        String   @id @default(uuid())
  requestId String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  sentAt    DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
